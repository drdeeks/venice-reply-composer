{
  "name": "venice-reply-composer",
  "version": "1.0.7",
  "description": "Browser extension for AI-powered social replies with Bankr integration",
  "main": "dist/background.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp src/content/content.css dist/content.css",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "deploy": "npm run build && zip -r dist/venice-reply-composer.zip dist/ icons/ manifest.json 2>/dev/null || zip -r dist/venice-reply-composer.zip dist/ manifest.json"
  },
  "keywords": [
    "venice",
    "bankr",
    "ai",
    "browser-extension",
    "social"
  ],
  "author": "Titan",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.260",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^5.2.0",
    "eslint": "^8.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^4.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "openai": "^6.29.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.3.0"
  }
}