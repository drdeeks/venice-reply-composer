{
  "name": "ai-agent-revenue-splitter",
  "version": "1.0.0",
  "description": "Automatic revenue distribution for Virtuals AI agents on Base",
  "main": "index.js",
  "scripts": {
    "build": "hardhat compile",
    "test": "hardhat test",
    "test:watch": "hardhat test --watch",
    "coverage": "hardhat test --coverage",
    "deploy:local": "hardhat deploy --network localhost",
    "deploy:testnet": "hardhat deploy --network base-testnet",
    "deploy:mainnet": "hardhat deploy --network base-mainnet",
    "console": "hardhat console --network localhost",
    "lint": "eslint contracts/ test/ scripts/ --ext .sol,.ts,.js",
    "format": "prettier --write contracts/ test/ scripts/",
    "verify": "hardhat verify --network base-mainnet",
    "generate": "./scripts/generate-hook.sh"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.8.0",
    "@openzeppelin/hardhat-upgrades": "^2.0.0",
    "@nomiclabs/hardhat-ethers": "^2.0.0",
    "@nomiclabs/hardhat-waffle": "^2.0.0",
    "hardhat": "^2.15.0",
    "hardhat-deploy": "^3.1.0",
    "hardhat-gas-reporter": "^2.0.0",
    "solidity-coverage": "^0.8.0",
    "@typechain/hardhat": "^7.0.0",
    "@typechain/ethers-v5": "^7.0.0",
    "ethers": "^5.7.0",
    "ts-node": "^10.9.0",
    "typescript": "^4.8.0",
    "dotenv": "^10.0.0",
    "@nomicfoundation/hardhat-toolbox": "^2.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomiclabs/hardhat-etherscan": "^3.0.0",
    "@nomiclabs/hardhat-solhint": "^3.0.0",
    "solhint": "^3.5.0",
    "prettier": "^2.8.0",
    "eslint": "^8.30.0",
    "@typescript-eslint/eslint-plugin": "^5.36.0",
    "@typescript-eslint/parser": "^5.36.0"
  },
  "keywords": [
    "solidity",
    "smart-contract",
    "defi",
    "virtuals",
    "slice",
    "base",
    "revenue-splitter"
  ],
  "author": "Project 9 Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/project-9/ai-agent-revenue-splitter.git"
  }
}