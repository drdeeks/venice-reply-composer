{
  "name": "uniswap-v4-hook-revenue-share",
  "version": "1.0.0",
  "description": "Uniswap v4 hook for revenue sharing with Slice payment splitter",
  "main": "src/index.ts",
  "scripts": {
    "test": "forge test -vvv",
    "test:coverage": "forge coverage",
    "test:gas": "forge test --gas-report",
    "deploy": "forge script scripts/Deploy.s.sol:deploy",
    "deploy:default": "forge script scripts/Deploy.s.sol:deployDefault",
    "configure": "forge script scripts/Deploy.s.sol:configure",
    "add-contributors": "forge script scripts/Deploy.s.sol:addContributors",
    "remove-contributor": "forge script scripts/Deploy.s.sol:removeContributor",
    "update-share": "forge script scripts/Deploy.s.sol:updateContributorShare",
    "withdraw": "forge script scripts/Deploy.s.sol:emergencyWithdraw",
    "stats": "forge script scripts/Deploy.s.sol:getStats",
    "contributor-info": "forge script scripts/Deploy.s.sol:getContributorInfo",
    "all-contributors": "forge script scripts/Deploy.s.sol:getAllContributors",
    "build": "forge build",
    "clean": "forge clean",
    "help": "forge help",
    "run": "node scripts/run.js"
  },
  "keywords": [
    "uniswap",
    "v4",
    "hook",
    "revenue-share",
    "slice",
    "payment-splitter",
    "defi",
    "smart-contracts"
  ],
  "author": "Synthesis Hackathon 2026",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^4.8.0",
    "forge-std": "^1.0.0",
    "@uniswap/v4-core": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/synthesis-hackathon/uniswap-v4-hook-revenue-share.git"
  },
  "bugs": {
    "url": "https://github.com/synthesis-hackathon/uniswap-v4-hook-revenue-share/issues"
  },
  "homepage": "https://github.com/synthesis-hackathon/uniswap-v4-hook-revenue-share#readme",
  "engines": {
    "node": ">=16.0.0"
  }
}