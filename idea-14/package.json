{
  "name": "@project14/contrib-attrib",
  "version": "1.0.0",
  "description": "Open Source Contributor Attribution Engine - Analyzes git history, computes contribution weights with Venice AI, encodes into Slice payment splitter, and attests to Talent Protocol",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "contrib-attrib": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepublishOnly": "npm run build",
    "docker:build": "docker build -t project14/contrib-attrib:latest .",
    "docker:run": "docker run --rm -v $(pwd):/work project14/contrib-attrib:latest analyze /work/repo"
  },
  "keywords": [
    "git",
    "contributors",
    "attribution",
    "venice-ai",
    "slice",
    "talent-protocol",
    "payment-splitter",
    "verifiable-credentials",
    "open-source"
  ],
  "author": "Project14 Hackathon",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "simple-git": "^3.22.0",
    "axios": "^1.6.0",
    "winston": "^3.11.0",
    "js-yaml": "^4.1.0",
    "ajv": "^8.12.0",
    "did-resolver": "^4.1.0",
    "vc-js": "^2.2.0",
    "merkletreejs": "^0.4.2",
    "ethers": "^5.7.2",
    "viem": "^1.19.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/project14-hackathon/contrib-attrib"
  },
  "bugs": {
    "url": "https://github.com/project14-hackathon/contrib-attrib/issues"
  },
  "homepage": "https://github.com/project14-hackathon/contrib-attrib#readme"
}
