{
  "name": "group-defi-savings-chat",
  "version": "0.1.0",
  "description": "Status Network group chat with DeFi savings pool (Lido staking + Uniswap LP)",
  "main": "index.js",
  "scripts": {
    "test": "hardhat test",
    "test:watch": "hardhat test --watch",
    "compile": "hardhat compile",
    "deploy:dev": "hardhat run scripts/deploy.js",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network mainnet",
    "lint": "eslint . --ext .js,.ts",
    "type-check": "tsc --noEmit",
    "start": "cd frontend && npm start",
    "build": "cd frontend && npm run build",
    "frontend-install": "cd frontend && npm install",
    "install-all": "npm install && npm run frontend-install"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.7.0",
    "@openzeppelin/hardhat-upgrades": "^1.9.0",
    "@status-im/contracts": "^0.1.0",
    "hardhat": "^2.18.0",
    "hardhat-deploy": "^1.7.0",
    "hardhat-deploy-ethers": "^1.1.0",
    "ethers": "^6.1.0",
    "@nomiclabs/hardhat-ethers": "^3.1.0",
    "@nomiclabs/hardhat-waffle": "^3.1.0",
    "waffle": "^4.0.0",
    "@nomiclabs/hardhat-etherscan": "^3.1.0",
    "solidity": "0.8.19",
    "chai": "^4.3.6",
    "@nomicfoundation/hardhat-toolbox": "^2.0.0",
    "@typechain/hardhat": "^9.1.0",
    "@typechain/ethers-v6": "^9.1.0",
    "ts-generator": "^0.2.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@hardhat/hackathon-boilerplate": "^1.0.0",
    "@hardhat/contract-sizer": "^2.0.0",
    "hardhat-contract-sizer": "^2.0.0",
    "hardhat-gas-reporter": "^2.0.0",
    "solhint": "^3.5.0",
    "@solidity-coverage/solidity-coverage": "^1.4.0"
  },
  "keywords": [
    "status",
    "defi",
    "lido",
    "uniswap",
    "group-chat",
    "savings"
  ],
  "author": "Dr Deek",
  "license": "MIT"
}