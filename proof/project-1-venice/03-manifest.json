{
  "manifest_version": 3,
  "name": "Venice AI Reply Composer",
  "version": "1.0.7",
  "description": "AI-powered reply suggestions with Bankr integration",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.farcaster.xyz/*",
    "https://farcaster.xyz/*",
    "https://*.warpcast.com/*",
    "https://warpcast.com/*",
    "https://*.farcaster.com/*",
    "https://farcaster.com/*",
    "https://*.twitter.com/*",
    "https://twitter.com/*",
    "https://*.x.com/*",
    "https://x.com/*",
    "https://*.reddit.com/*",
    "https://reddit.com/*",
    "https://api.venice.ai/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.farcaster.xyz/*",
        "https://farcaster.xyz/*",
        "https://*.warpcast.com/*",
        "https://warpcast.com/*",
        "https://*.farcaster.com/*",
        "https://farcaster.com/*",
        "https://*.twitter.com/*",
        "https://twitter.com/*",
        "https://*.x.com/*",
        "https://x.com/*",
        "https://*.reddit.com/*",
        "https://reddit.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  }
}
